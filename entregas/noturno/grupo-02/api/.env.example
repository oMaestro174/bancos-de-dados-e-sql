# Porta em que a API vai rodar
PORT=3001

# Conexão com o MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=escola_db

CORS_ORIGIN=http://localhost:5173

# Autenticação (JWT)
# Troque por um valor longo e aleatório em produção.
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-e-longo
JWT_EXPIRES=8h

# Usuário administrador criado automaticamente se a tabela estiver vazia
ADMIN_NOME=Coordenação Acadêmica
ADMIN_EMAIL=admin@escola.edu.br
ADMIN_SENHA=admin123